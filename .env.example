# =============================================================================
# Python
# =============================================================================
PYTHONPATH=../../../
PYTHONDONTWRITEBYTECODE=1
PYTHONUNBUFFERED=1

# =============================================================================
# App
# =============================================================================
ENV=local
LOG_LEVEL=DEBUG
# Deployment mode: "self-hosted" (unlimited, no Statsig) or "cloud" (Statsig-managed limits)
DEPLOYMENT_MODE=self-hosted

# =============================================================================
# Database
# =============================================================================
DATABASE__URI=postgresql://minds:minds@localhost:35432/minds
# Connection pool
DATABASE__MAX_OVERFLOW=20
DATABASE__POOL_PRE_PING=true
DATABASE__POOL_RECYCLE=300
DATABASE__POOL_SIZE=20
DATABASE__POOL_TIMEOUT=300
# Query timeouts
DATABASE__QUERY_TIMEOUT=300
DATABASE__STATEMENT_TIMEOUT=300000

# =============================================================================
# OpenAI
# =============================================================================
OPENAI__API_URL=https://api.openai.com/v1
OPENAI__API_KEY=
OPENAI__MAX_TOKENS=400000
OPENAI__SUPPORTED_MODELS='["gpt-4o","gpt-4.1","gpt-5.2"]'
# Passthrough-agent alias → OpenAI model mappings. Aliases are versionless
# (`latest:gpt`, `latest:gpt-mini`); the upstream model identifier lives
# here so a point-release is a one-env-var change.
OPENAI__PASSTHROUGH_GPT_MODEL=gpt-5.5
OPENAI__PASSTHROUGH_GPT_CODEX_MODEL=gpt-5.3-codex
OPENAI__PASSTHROUGH_GPT_MINI_MODEL=gpt-5.4-mini
OPENAI__PASSTHROUGH_GPT_NANO_MODEL=gpt-5.4-nano

# =============================================================================
# Anthropic
# =============================================================================
ANTHROPIC__API_KEY=
ANTHROPIC__SUPPORTED_MODELS='["claude-sonnet-4-5","claude-opus-4-5","claude-opus-4-6"]'
# Native web-tool versions used by the passthrough agent. Required (no defaults)
# so version bumps are an explicit config change.
ANTHROPIC__WEB_SEARCH_TOOL_TYPE=web_search_20250305
ANTHROPIC__WEB_FETCH_TOOL_TYPE=web_fetch_20250910
ANTHROPIC__WEB_FETCH_BETA_HEADER=web-fetch-2025-09-10
# Passthrough-agent alias → Anthropic model mappings.
ANTHROPIC__PASSTHROUGH_SONNET_MODEL=claude-sonnet-4-6
ANTHROPIC__PASSTHROUGH_OPUS_MODEL=claude-opus-4-7
ANTHROPIC__PASSTHROUGH_HAIKU_MODEL=claude-haiku-4-5-20251001

# =============================================================================
# Fireworks.ai (open-source models via Anthropic-compatible API)
# Used by the passthrough_agent for `latest:kimi`, `latest:deepseek`,
# `latest:qwen` aliases.
# =============================================================================
FIREWORKS__API_KEY=
FIREWORKS__ANTHROPIC_BASE_URL=https://api.fireworks.ai/inference
FIREWORKS__PASSTHROUGH_KIMI_MODEL=accounts/fireworks/models/kimi-k2p6
FIREWORKS__PASSTHROUGH_DEEPSEEK_MODEL=accounts/fireworks/models/deepseek-v4-pro
FIREWORKS__PASSTHROUGH_QWEN_MODEL=accounts/fireworks/models/qwen3p6-plus

# =============================================================================
# Google Gemini
# Used by the passthrough_agent for the `latest:gemini` alias.
# =============================================================================
GEMINI__API_KEY=
GEMINI__PASSTHROUGH_GEMINI_MODEL=gemini-3.1-pro-preview

# =============================================================================
# Default Models
# =============================================================================
DEFAULT_MODELS__DEFAULT_PROVIDER=openai
DEFAULT_MODELS__OPENAI_MODEL=gpt-4o
DEFAULT_MODELS__ANTHROPIC_MODEL=claude-sonnet-4-5

# =============================================================================
# MindsDB
# =============================================================================
MINDSDB__URL=http://localhost:47334
MINDSDB__API_KEY=
MINDSDB__LOGIN=mindsdb
MINDSDB__PASSWORD=

# =============================================================================
# Data Catalog
# =============================================================================
DATA_CATALOG__EXECUTION_MODE=asynchronous
DATA_CATALOG__JOB_NAME=load-data-catalog
DATA_CATALOG__JOB_DEPLOYMENT_NAME=local--data-catalog-loader
DATA_CATALOG__CACHE_TYPE=in_memory
DATA_CATALOG__CACHE_MAX_SIZE=100

# =============================================================================
# Redis
# =============================================================================
REDIS__DB=0
REDIS__HOST=localhost
REDIS__PORT=6379
REDIS__CACHE_TTL=3600

# =============================================================================
# Minds
# =============================================================================
MINDS__MAX_DISPLAY_ROWS=100
MINDS__MAX_COLUMN_WIDTH=300
MINDS__MAX_SQL_RETRIES=4
MINDS__ENABLE_MODEL_SELECTION=false

# =============================================================================
# MindCastle
# =============================================================================
MIND_CASTLE__ENCRYPTION_TYPE=localencryption

# =============================================================================
# Statsig
# =============================================================================
STATSIG__SDK_KEY=
STATSIG__ENVIRONMENT=
STATSIG__DISABLE_NETWORK=true
STATSIG__DISABLE_ALL_LOGGING=true

# =============================================================================
# Feature Flags
# =============================================================================
FEATURE_FLAG_ENABLE_LANGFUSE__NAME=enable-langfuse
FEATURE_FLAG_ENABLE_LANGFUSE__DEFAULT_VALUE=true

# =============================================================================
# Langfuse
# =============================================================================
LANGFUSE_ENABLED=true
LANGFUSE_HOST=http://localhost:13000
LANGFUSE_PORT=13000

# =============================================================================
# Testing
# =============================================================================
MINDS_API_BASE_URL=https://staging.mdb.ai
MINDS_API_KEY=mdb_...
